# ---------------------------------------------------------------------------
# screener_job — composite score → multi-agent debate → picks write → email
#
# Build:
#   docker build -f docker/Dockerfile.screener -t screener_job .
# Run locally:
#   docker run --env-file .env screener_job
# ---------------------------------------------------------------------------
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        gcc \
        libxml2-dev \
        libxslt1-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

CMD ["python", "jobs/screener/main.py"]
