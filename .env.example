# ---------------------------------------------------------------------------
# Multi-Agent Stock Screener — Secrets Template
#
# Copy this file to .env and fill in real values.
# The .env file is git-ignored — never commit real secrets.
#
# Values here are loaded by screener/lib/config.py at startup via
# pydantic-settings (reads .env automatically when python-dotenv is present).
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# LLM provider API keys
# Only the key(s) matching the provider(s) you configured in config.yaml are
# required.  Leave unused providers blank.
# ---------------------------------------------------------------------------

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Ollama — no key needed; set the base URL if not running on localhost
# OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# GCP credentials
# Required when storage.provider = "firestore" (the default).
# ---------------------------------------------------------------------------

# Path to a GCP service-account JSON key file, OR leave blank and use
# Application Default Credentials (ADC) if running on GCP infrastructure.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GCP project that hosts your Firestore database.
GCP_PROJECT_ID=my-gcp-project

# ---------------------------------------------------------------------------
# Storage: S3 (only needed when storage.provider = "s3")
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=my-stock-screener-bucket

# ---------------------------------------------------------------------------
# Storage: OpenSearch (only needed when storage.provider = "opensearch")
# ---------------------------------------------------------------------------
OPENSEARCH_HOST=localhost
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=...

# ---------------------------------------------------------------------------
# Email (Resend) — https://resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_...
