# ---------------------------------------------------------------------------
# edgar_disclosure_job — indexes 10-K/10-Q filings into the vector store
#
# Build:
#   docker build -f docker/Dockerfile.edgar_disclosure -t edgar_disclosure_job .
# Run locally:
#   docker run --env-file .env edgar_disclosure_job
# ---------------------------------------------------------------------------
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        gcc \
        libxml2-dev \
        libxslt1-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

CMD ["python", "jobs/edgar_disclosure/main.py"]
